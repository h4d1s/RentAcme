{
  "realm": "rent-acme",
  "enabled": true,
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,

  "eventsEnabled": true,
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "eventsListeners": [
    "jboss-logging",
    "keycloak-to-rabbitmq"
  ],
  "enabledEventTypes": [
    "REGISTER",
    "LOGIN",
    "LOGOUT",
    "CREATE_USER",
    "DELETE_USER",
    "UPDATE_PROFILE"
  ],

  "smtpServer": {
    "host": "mailhog",
    "port": "1025",
    "from": "noreply@rent-acme.com",
    "fromDisplayName": "Rent Acme Auth",
    "auth": "false",
    "ssl": "false",
    "starttls": "false"
  },

  "defaultRoles": [ "Customer" ],

  "roles": {
    "realm": [
      {
        "name": "Customer",
        "description": "Customer",
        "composites": {
          "client": {
            "rent-acme-api": [
              "booking.reserve",
              "booking.cancel",
              "booking.view.own"
            ]
          }
        }
      },
      {
        "name": "Admin",
        "description": "Full access to all resources",
        "composites": {
          "client": {
            "rent-acme-api": [
              "booking.reserve",
              "booking.cancel",
              "booking.complete",
              "booking.view.own",
              "booking.view.any",

              "brand.create",
              "brand.update.own",
              "brand.update.any",
              "brand.delete.own",
              "brand.delete.any",
              "model.create",
              "model.update.own",
              "model.update.any",
              "model.delete.own",
              "model.delete.any",
              "variant.create",
              "variant.update.own",
              "variant.update.any",
              "variant.delete.own",
              "variant.delete.any",
              "vehicle.create",
              "vehicle.update.own",
              "vehicle.update.any",
              "vehicle.delete.own",
              "vehicle.delete.any",

              "user.view.own",
              "user.view.any",
              "user.update.own",
              "user.update.any",
              "user.delete.own",
              "user.delete.any"
            ]
          }
        }
      }
    ],
    "client": {
      "rent-acme-api": [
        { "name": "booking.reserve" },
        { "name": "booking.cancel" },
        { "name": "booking.complete" },
        { "name": "booking.view.own" },
        { "name": "booking.view.any" },

        { "name": "brand.create" },
        { "name": "brand.update.own" },
        { "name": "brand.update.any" },
        { "name": "brand.delete.own" },
        { "name": "brand.delete.any" },
        { "name": "model.create" },
        { "name": "model.update.own" },
        { "name": "model.update.any" },
        { "name": "model.delete.own" },
        { "name": "model.delete.any" },
        { "name": "variant.create" },
        { "name": "variant.update.own" },
        { "name": "variant.update.any" },
        { "name": "variant.delete.own" },
        { "name": "variant.delete.any" },
        { "name": "vehicle.create" },
        { "name": "vehicle.update.own" },
        { "name": "vehicle.update.any" },
        { "name": "vehicle.delete.own" },
        { "name": "vehicle.delete.any" },

        { "name": "user.view.own" },
        { "name": "user.view.any" },
        { "name": "user.update.own" },
        { "name": "user.update.any" },
        { "name": "user.delete.own" },
        { "name": "user.delete.any" }
      ]
    }
  },
  "clientScopes": [
    {
      "name": "openid",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "id",
            "claim.name": "sub",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "access.token.claim": "true",
            "multivalued": "true"
          }
        }
      ]
    },
    {
      "name": "rent-acme-web-scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "permissions-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "config": {
            "claim.name": "permissions",
            "access.token.claim": "true",
            "multivalued": "true",
            "usermodel.clientRoleMapping.clientId": "rent-acme-api"
          }
        },
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "rent-acme-aud",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],

  "users": [
