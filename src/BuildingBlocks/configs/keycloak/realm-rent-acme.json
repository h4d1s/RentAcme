{
  "realm": "rent-acme",
  "enabled": true,
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,

  "eventsEnabled": true,
  "eventsListeners": [
    "jboss-logging",
    "keycloak-to-rabbitmq"
  ],
  "enabledEventTypes": [
    "REGISTER",
    "LOGIN",
    "LOGOUT",
    "CREATE_USER",
    "DELETE_USER",
    "UPDATE_PROFILE"
  ],
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,

  "smtpServer": {
