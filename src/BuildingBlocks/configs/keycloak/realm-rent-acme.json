      "credentials": [
        {
          "type": "password",
          "value": "Passw0rd!",
          "temporary": false
        }
      ],
      "realmRoles": [ "Customer" ]
    }
  ],

  "clients": [
    {
      "clientId": "rent-acme-web",
      "name": "Rent Acme Web Frontend",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "https://oauth.pstmn.io/v1/callback"
      ],
      "webOrigins": [
        "+"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "rent-acme-web-scope"
      ]
    },
    {
      "clientId": "rent-acme-api",
      "name": "Rent Acme Backend Service",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "e4a7066a-7724-42b1-912b-3134608a0022",
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "rent-acme-web-scope"
      ]
    }
  ]
}