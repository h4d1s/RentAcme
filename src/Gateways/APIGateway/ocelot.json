{
  "Routes": [
    {
      "UseServiceDiscovery": false,
      "DownstreamHostAndPorts": [
        {
          "Host": "user-api",
          "Port": 8081
        }
      ],
      "DangerousAcceptAnyServerCertificateValidator": true,
      "DownstreamPathTemplate": "/api/{version}/{everything}",
      "UpstreamPathTemplate": "/api/{version}/accounts/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "DownstreamScheme": "https",
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "5s",
        "Limit": 100,
        "PeriodTimespan": 2
      }
    },
    {
      "UseServiceDiscovery": false,
      "DownstreamHostAndPorts": [
        {
          "Host": "inventory-api",
          "Port": 8081
        }
      ],
      "DangerousAcceptAnyServerCertificateValidator": true,
      "DownstreamPathTemplate": "/api/{version}/{everything}",
      "UpstreamPathTemplate": "/api/{version}/inventories/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "DownstreamScheme": "https",
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "5s",
        "Limit": 100,
        "PeriodTimespan": 2
      }
    },
    {
      "UseServiceDiscovery": false,
      "DownstreamHostAndPorts": [
        {
          "Host": "reservation-api",
          "Port": 8081
        }
      ],
      "DangerousAcceptAnyServerCertificateValidator": true,
      "DownstreamPathTemplate": "/api/{version}/{everything}",
      "UpstreamPathTemplate": "/api/{version}/reservations/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "DownstreamScheme": "https",
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "5s",
        "Limit": 100,
        "PeriodTimespan": 2
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://apigateway:8080",
    "ServiceDiscoveryProvider": {
      "Host": "consul",
      "Port": 8500,
      "Type": "Consul"
    },
    "RateLimitOptions": {
      "DisableRateLimitHeaders": false,
      "HttpStatusCode": 429,
      "ClientIdHeader": "ClientId"
    }
  }
}